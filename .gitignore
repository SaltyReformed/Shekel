# Shekel Budget App -- Git Ignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Environment / secrets
.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Alembic
migrations/versions/__pycache__/

# Testing
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Docker
pgdata/

# Logs
logs/

# Pylint
.pylintrc_cache/

# Worktrees
.worktrees/

# Per-app runtime state.  In production this lives in the
# ``shekel-prod-app-state`` named volume mounted at
# /home/shekel/app/state, but the dev compose bind-mounts the entire
# repo into the container so entrypoint.sh's ``mkdir -p`` would
# create the directory inside the host's checkout.  Ignoring it here
# prevents the seed-complete sentinel from accidentally landing in a
# commit.  See audit finding F-022 / Commit C-34.
state/

# Claude Code session-local state.  scheduled_tasks.lock holds the
# active session's PID and wakeup-scheduling metadata; it is rewritten
# every time /loop or ScheduleWakeup runs and must not be tracked.
# settings.local.json is per-machine overrides for the team-shared
# .claude/settings.json.
.claude/scheduled_tasks.lock
.claude/settings.local.json
