{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/hooks/guard-migrations.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/hooks/post-edit-python.sh"
          },
          {
            "type": "command",
            "command": "scripts/hooks/post-edit-template.sh"
          },
          {
            "type": "command",
            "command": "scripts/hooks/post-edit-deps.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/hooks/stop-check.sh"
          }
        ]
      }
    ]
  }
}
