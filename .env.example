# Shekel Budget App -- Environment Configuration
#
# Copy this file to .env and fill in your values.
# Variables marked REQUIRED must be set before running in production.
# Variables with defaults can be omitted to use the default value.

# ── Flask Core ───────────────────────────────────────────────────
# REQUIRED -- the application refuses to start without a real value.
# Do NOT deploy with a placeholder; the production config rejects
# the historically-leaked defaults and any value shorter than 32
# characters.  Generate with one of:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then paste the 64-character hex string after the equals sign.
SECRET_KEY=

# Application environment: development, testing, or production.
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection URI.
# If unset, DevConfig falls back to postgresql:///shekel (peer auth,
# local Unix socket).  Set this explicitly if you use password auth
# or a remote database.
DATABASE_URL=postgresql://shekel_user:shekel_pass@localhost:5432/shekel
# Test database (used by pytest).
# If unset, TestConfig falls back to postgresql:///shekel_test.
TEST_DATABASE_URL=postgresql://shekel_user:shekel_pass@localhost:5433/shekel_test

# REQUIRED in production. PostgreSQL password used by docker-compose.yml
# to configure both the db service and the app's DATABASE_URL.
POSTGRES_PASSWORD=shekel_pass

# REQUIRED in production. Password for the least-privilege
# ``shekel_app`` PostgreSQL role.  entrypoint.sh creates the role
# under this password and constructs DATABASE_URL_APP from it just
# before exec'ing Gunicorn, so the runtime app uses DML-only
# credentials while migrations and seed scripts continue to run as
# the owner role.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Required minimum length: 16 characters (entrypoint.sh enforces
# this).  See audit finding F-081 / remediation Commit C-13.
APP_ROLE_PASSWORD=

# Docker entrypoint database connection overrides.
# These are used by entrypoint.sh to wait for PostgreSQL and create schemas.
# Defaults match docker-compose.yml and rarely need changing.
# DB_HOST=db
# DB_PORT=5432
# DB_USER=shekel_user
# DB_NAME=shekel

# ── Authentication & Security ────────────────────────────────────
# Fernet key for encrypting TOTP secrets at rest.
# Optional for initial setup. Required before any user enables MFA.
# The app will start without it but MFA/TOTP will be unavailable.
#
# Generate with:
#   docker run --rm ghcr.io/saltyreformed/shekel:latest python -c \
#     "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# If you have Python and cryptography installed locally:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# Optional comma-separated list of retired TOTP encryption keys.
# Set ONLY during a key rotation: place the previous primary value
# here so the application can still decrypt ciphertexts written
# before the rotation, then remove it again after running
# scripts/rotate_totp_key.py to re-wrap all ciphertexts under the
# new primary.  See docs/runbook_secrets.md "Rotating
# TOTP_ENCRYPTION_KEY" for the full non-destructive procedure.
#
# Steady-state production posture: leave this unset or empty.
# Multiple retired keys (e.g. during a long-running migration) may
# be listed comma-separated:
#     TOTP_ENCRYPTION_KEY_OLD=key-from-previous-rotation,older-key
# Whitespace and stray empty entries between commas are ignored.
TOTP_ENCRYPTION_KEY_OLD=

# Public-registration toggle.  Set to 'true' to enable the /register
# endpoint and the "Create an account" link on /login.
#
# Production posture: false.  A personal-finance app intended for a
# known user set should not ship with an open registration surface;
# operators who want public registration must explicitly opt in.
# When disabled, /register returns 404 (not 403, to avoid confirming
# the endpoint exists) and the registration link is hidden on the
# login form.
#
# Defaults at every layer: docker-compose.yml's interpolation default
# is ``false``; ProdConfig in app/config.py also defaults to ``false``.
# BaseConfig (used by DevConfig and TestConfig) defaults to ``true`` so
# local development and the test suite do not require an env-var flip
# to exercise the registration flow.  See audit finding F-053 and
# remediation Commit C-34.
REGISTRATION_ENABLED=false

# Session "remember me" duration in days.  Default: 7 (was 30
# pre-C-10).  ASVS L2 guidance for financial apps: a stolen
# remember-me cookie is a password-equivalent credential, so the
# legitimate-UX vs. stolen-device-blast-radius tradeoff favours a
# shorter window.  See audit finding F-006.
REMEMBER_COOKIE_DURATION_DAYS=7

# Hard cap on the lifetime of a permanent (logged-in) session
# cookie, in hours.  Default: 12.  Replaces Flask's 31-day fallback
# so a stolen browser profile cannot retain auth for a month after
# a single sign-in.  See audit finding F-035.
SESSION_LIFETIME_HOURS=12

# Maximum gap between authenticated requests before the loader
# rejects the session, in minutes.  Default: 30.  Refreshed on
# every authenticated request via a before_request hook; checked
# in load_user against ``_session_last_activity_at``.  Defends
# against the "I left the browser open at the coffee shop"
# scenario.  See audit finding F-006.
IDLE_TIMEOUT_MINUTES=30

# Maximum age of the most recent password verification before
# ``fresh_login_required`` redirects to /reauth, in minutes.
# Default: 5 (ASVS L2 V4.3.3).  Applied to anchor-balance changes,
# companion management, tax-config edits, account hard-delete --
# the high-value operations a session-hijack attacker could
# otherwise execute without re-typing a password.  See audit
# finding F-045.
FRESH_LOGIN_MAX_AGE_MINUTES=5

# ── Rate Limiting ────────────────────────────────────────────────
# Storage backend URI for Flask-Limiter counters.
#
# Production (FLASK_ENV=production):
#   ProdConfig defaults this to "redis://redis:6379/0", pointing at
#   the bundled docker-compose redis service.  ProdConfig refuses to
#   start with a "memory://" URI (which would silently fragment
#   counters across Gunicorn workers -- see audit finding F-034).
#   Override only if you replace the bundled service with managed
#   Redis (Upstash, ElastiCache, etc.).
#
# Development (FLASK_ENV=development):
#   DevConfig defaults to "memory://" so `flask run` works without a
#   Redis container.  Each `flask run` process has its own counters,
#   which reset on every restart -- acceptable for local development.
#
# Testing:
#   TestConfig forces "memory://" regardless of this variable so the
#   pytest suite never depends on an external Redis.
#
# RATELIMIT_STORAGE_URI=redis://redis:6379/0

# ── Seed User (optional, first run only) ─────────────────────────
# If set, entrypoint.sh creates this user on first boot with a
# checking account, baseline scenario, and 22 default categories.
# The script is idempotent at the database level (it will skip an
# existing user) and entrypoint.sh additionally writes a sentinel
# file to ``/home/shekel/app/state/.seed-complete`` after the first
# successful run so subsequent restarts skip the script entirely.
#
# Alternative: leave these empty and register at /register instead.
# Registration creates the same bootstrap data.
#
# Password must be at least 12 characters.
#
# CREDENTIAL HYGIENE (audit finding F-022 / Commit C-34):
#   1. After the first successful boot, REMOVE the SEED_USER_PASSWORD
#      and SEED_USER_EMAIL lines from this file.
#   2. Recreate the app container so Docker's stored Config.Env no
#      longer carries the password:
#          docker compose up -d --force-recreate app
#   3. Verify the scrub:
#          docker exec shekel-prod-app env | grep -c SEED_USER_PASSWORD
#      Should print ``0``.
#   The Python script (scripts/seed_user.py) and entrypoint.sh both
#   scrub these values from /proc/<pid>/environ at runtime, but the
#   stored Container.Config.Env channel is closed only by removing
#   the values here -- planned to be replaced with Docker secrets in
#   Commit C-38.
SEED_USER_EMAIL=admin@shekel.local
SEED_USER_PASSWORD=ChangeMe!2026
SEED_USER_DISPLAY_NAME=Budget Admin

# ── Logging ──────────────────────────────────────────────────────
# Application log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Requests slower than this threshold (ms) are logged at WARNING level.
SLOW_REQUEST_THRESHOLD_MS=500

# ── Audit ────────────────────────────────────────────────────────
# Days to retain audit_log rows before cleanup by audit_cleanup.py.
AUDIT_RETENTION_DAYS=365

# ── Gunicorn (production only) ───────────────────────────────────
# Number of Gunicorn worker processes. Default: 2.
# Formula for higher load: (2 * CPU cores) + 1.
GUNICORN_WORKERS=2

# Port Gunicorn listens on inside the container. Default: 8000.
# Nginx reverse-proxies to this port.
# GUNICORN_PORT=8000

# Worker and graceful shutdown timeouts in seconds. Default: 120.
# 120s accommodates slow operations like 2-year recurrence regeneration.
# GUNICORN_TIMEOUT=120
# GUNICORN_GRACEFUL_TIMEOUT=120

# Gunicorn process-level log level (separate from app LOG_LEVEL).
# GUNICORN_LOG_LEVEL=info

# Gunicorn trusted proxy IPs.  Required (no fallback default in
# gunicorn.conf.py): a missing or empty value fails the gunicorn
# config load before any worker starts.  Audit finding F-015,
# Commit C-33.
#
# Set to the IP/CIDR of the trusted reverse proxy ONLY.  Trusting
# wider RFC 1918 ranges lets a co-tenant on the same Docker bridge
# forge X-Forwarded-For / CF-Connecting-IP and bypass per-IP rate
# limiting.
#
# Default for the bundled docker-compose.yml is 172.31.0.0/24 (the
# pinned ``backend`` bridge that hosts only the in-stack nginx and
# the app); the deploy/docker-compose.prod.yml shared-mode override
# repins this to 172.32.0.0/24 (the ``shekel-frontend`` bridge).
# Both defaults work out of the box; override only if the matching
# bridge subnet is repinned.
# FORWARDED_ALLOW_IPS=172.31.0.0/24

# ── Nginx ────────────────────────────────────────────────────────
# Host port for Nginx. Default: 80.
# Override if port 80 is already in use on the host.
NGINX_PORT=80

# ── Backups ──────────────────────────────────────────────────────
# Local directory for backup files (host path, not inside container).
BACKUP_LOCAL_DIR=/var/backups/shekel

# NAS mount point for off-site backup copies.
BACKUP_NAS_DIR=/mnt/nas/backups/shekel

# GPG passphrase for encrypting backups at rest (optional).
# If empty, backups are stored unencrypted.
# WARNING: Store this passphrase separately from the backups themselves.
BACKUP_ENCRYPTION_PASSPHRASE=

# Retention periods for backup pruning (backup_retention.sh).
RETENTION_DAILY_DAYS=7
RETENTION_WEEKLY_WEEKS=4
RETENTION_MONTHLY_MONTHS=6

# ── Docker Container Names ───────────────────────────────────────
# Override these if running multiple Shekel instances on the same host.
# Used by backup, restore, verify, and deploy scripts.
# DB_CONTAINER=shekel-prod-db
# APP_CONTAINER=shekel-prod-app

# PostgreSQL user/database for backup and restore scripts.
# Defaults match docker-compose.yml.
# PGUSER=shekel_user
# PGDATABASE=shekel

# Temporary database name used by verify_backup.sh for restore testing.
# VERIFY_DB=shekel_verify

# ── Deployment ───────────────────────────────────────────────────
# Directory where the Shekel repository is cloned on the Proxmox host.
# Used by deploy.sh.
# DEPLOY_DIR=/opt/shekel

# Seconds to wait for the health endpoint after deploy. Default: 60.
# HEALTH_TIMEOUT=60

# Seconds between health check retries. Default: 5.
# HEALTH_INTERVAL=5

# Docker Compose project name. Defaults to directory name.
# COMPOSE_PROJECT_NAME=shekel

# REQUIRED in shared-mode production. Immutable digest of the GHCR
# image to deploy. ``deploy/docker-compose.prod.yml`` interpolates
# this value with ``${SHEKEL_IMAGE_DIGEST:?...}``: a missing or empty
# value FAILS ``docker compose up`` with a clear remediation message
# (see audit findings F-060 and F-155 / Commit C-36).
#
# Format: include the ``sha256:`` prefix; the compose file already
# supplies the ``@`` separator before the value.
#
# Capture the new digest after each rebuild:
#   * CI builds (.github/workflows/docker-publish.yml) emit the
#     digest in the "Image digest" step output.
#   * Local builds via ``scripts/deploy.sh`` print the digest after
#     ``cosign sign`` succeeds.
#
# Then verify the signature before committing the new value:
#   cosign verify ghcr.io/saltyreformed/shekel@<digest>
#
# After updating, recreate the app container so it pulls the new
# pinned digest:
#   docker compose -f docker-compose.yml -f docker-compose.override.yml up -d app
#
# See deploy/README.md "Image digest pinning" for the full
# rotation and rollback procedure.
SHEKEL_IMAGE_DIGEST=

# OPTIONAL. Path to the Cosign public key used to verify the
# locally-built image in ``scripts/deploy.sh`` (Commit C-36).  The
# script auto-detects ``deploy/cosign.pub`` and verifies signatures
# only when the file is present, so a fresh checkout without a
# generated keypair still deploys; once the operator runs
# ``cosign generate-key-pair`` and commits the public key, every
# deploy enforces signature verification.  Override here only when
# the key lives outside the repo (e.g., in /etc/shekel/cosign.pub).
# COSIGN_PUBLIC_KEY=deploy/cosign.pub

# OPTIONAL. Promote Cosign warnings to errors.  When ``true``,
# ``scripts/deploy.sh`` REFUSES to deploy if cosign is not installed
# or if signature verification fails.  Defaults to false so a fresh
# checkout without cosign installed still completes a deploy with a
# warning (suitable for the first-run bring-up).  Set to ``true`` in
# steady-state production .env files once the keypair is in place.
# COSIGN_REQUIRED=false

# ── External Reverse Proxy ────────────────────────────────────────
# If you use a central Nginx (or Traefik/Caddy) instead of the
# bundled shekel-nginx service, set EXTERNAL_NETWORK to the Docker
# network your reverse proxy is on.  See README > Deploying Behind
# an Existing Reverse Proxy.
# EXTERNAL_NETWORK=homelab
