# Shekel Budget App — Environment Configuration
#
# Copy this file to .env and fill in your values.
# Variables marked REQUIRED must be set before running in production.
# Variables with defaults can be omitted to use the default value.

# ── Flask Core ───────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Application environment: development, testing, or production.
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────
# REQUIRED. PostgreSQL connection URI.
# Development (local Flask + Docker PostgreSQL):
DATABASE_URL=postgresql://shekel_user:shekel_pass@localhost:5432/shekel
# Test database (used by pytest):
TEST_DATABASE_URL=postgresql://shekel_user:shekel_pass@localhost:5433/shekel_test

# REQUIRED in production. PostgreSQL password used by docker-compose.yml
# to configure both the db service and the app's DATABASE_URL.
POSTGRES_PASSWORD=shekel_pass

# Docker entrypoint database connection overrides.
# These are used by entrypoint.sh to wait for PostgreSQL and create schemas.
# Defaults match docker-compose.yml and rarely need changing.
# DB_HOST=db
# DB_PORT=5432
# DB_USER=shekel_user
# DB_NAME=shekel

# ── Authentication & Security ────────────────────────────────────
# REQUIRED. Fernet key for encrypting TOTP secrets at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# Session "remember me" duration in days.
REMEMBER_COOKIE_DURATION_DAYS=30

# ── Seed User (first run only) ──────────────────────────────────
# Set these before first `docker compose up`. The initial user is
# created automatically by entrypoint.sh. Remove or leave empty
# after first run.
SEED_USER_EMAIL=admin@shekel.local
SEED_USER_PASSWORD=changeme
SEED_USER_DISPLAY_NAME=Budget Admin

# ── Logging ──────────────────────────────────────────────────────
# Application log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Requests slower than this threshold (ms) are logged at WARNING level.
SLOW_REQUEST_THRESHOLD_MS=500

# ── Audit ────────────────────────────────────────────────────────
# Days to retain audit_log rows before cleanup by audit_cleanup.py.
AUDIT_RETENTION_DAYS=365

# ── Gunicorn (production only) ───────────────────────────────────
# Number of Gunicorn worker processes. Default: 2.
# Formula for higher load: (2 * CPU cores) + 1.
GUNICORN_WORKERS=2

# Port Gunicorn listens on inside the container. Default: 8000.
# Nginx reverse-proxies to this port.
# GUNICORN_PORT=8000

# Worker and graceful shutdown timeouts in seconds. Default: 120.
# 120s accommodates slow operations like 2-year recurrence regeneration.
# GUNICORN_TIMEOUT=120
# GUNICORN_GRACEFUL_TIMEOUT=120

# Gunicorn process-level log level (separate from app LOG_LEVEL).
# GUNICORN_LOG_LEVEL=info

# ── Nginx ────────────────────────────────────────────────────────
# Host port for Nginx. Default: 80.
# Override if port 80 is already in use on the host.
NGINX_PORT=80

# ── Backups ──────────────────────────────────────────────────────
# Local directory for backup files (host path, not inside container).
BACKUP_LOCAL_DIR=/var/backups/shekel

# NAS mount point for off-site backup copies.
BACKUP_NAS_DIR=/mnt/nas/backups/shekel

# GPG passphrase for encrypting backups at rest (optional).
# If empty, backups are stored unencrypted.
# WARNING: Store this passphrase separately from the backups themselves.
BACKUP_ENCRYPTION_PASSPHRASE=

# Retention periods for backup pruning (backup_retention.sh).
RETENTION_DAILY_DAYS=7
RETENTION_WEEKLY_WEEKS=4
RETENTION_MONTHLY_MONTHS=6

# ── Docker Container Names ───────────────────────────────────────
# Override these if running multiple Shekel instances on the same host.
# Used by backup, restore, verify, and deploy scripts.
# DB_CONTAINER=shekel-db
# APP_CONTAINER=shekel-app

# PostgreSQL user/database for backup and restore scripts.
# Defaults match docker-compose.yml.
# PGUSER=shekel_user
# PGDATABASE=shekel

# Temporary database name used by verify_backup.sh for restore testing.
# VERIFY_DB=shekel_verify

# ── Deployment ───────────────────────────────────────────────────
# Directory where the Shekel repository is cloned on the Proxmox host.
# Used by deploy.sh.
# DEPLOY_DIR=/opt/shekel

# Seconds to wait for the health endpoint after deploy. Default: 60.
# HEALTH_TIMEOUT=60

# Seconds between health check retries. Default: 5.
# HEALTH_INTERVAL=5

# Docker Compose project name. Defaults to directory name.
# COMPOSE_PROJECT_NAME=shekel
